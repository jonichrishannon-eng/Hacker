---
import Layout from '../layouts/Layout.astro';
import BootScreen from '../components/BootScreen.astro';
import ModColumnLeft from '../components/ModColumnLeft.astro';
import ModColumnRight from '../components/ModColumnRight.astro';
import MainShell from '../components/MainShell.astro';
import FileSystem from '../components/FileSystem.astro';
import Keyboard from '../components/Keyboard.astro';
import ThemeSelector from '../components/ThemeSelector.astro';
---

<Layout>
    <BootScreen />
    <ThemeSelector />

    <div class="w-full h-screen p-4 flex flex-col overflow-hidden">
        <!-- Top row: System Panels + Main Shell -->
        <div class="flex-grow flex flex-row gap-4 h-[60%]">

            <!-- Left Column -->
            <div class="w-1/4 h-full">
                <ModColumnLeft>
                    <div class="edex-panel p-2 text-xs flex-grow flex flex-col justify-between" data-augmented-ui="tl-clip br-clip exe">
                        <div>
                            <div class="mb-1"><span class="font-bold">OS:</span> eDEX-UI Web</div>
                            <div class="mb-1"><span class="font-bold">KERNEL:</span> Browser Engine</div>
                            <div><span class="font-bold">UPTIME:</span> <span id="uptime">00:00:00</span></div>
                        </div>
                    </div>
                    <div class="edex-panel p-2 flex-grow" data-augmented-ui="tr-clip bl-clip exe">
                        <h4 class="text-xs mb-1 border-b border-[rgba(var(--color_r),var(--color_g),var(--color_b),0.3)]">CPU Usage</h4>
                        <div class="h-16 w-full border border-[rgba(var(--color_r),var(--color_g),var(--color_b),0.3)] bg-[rgba(var(--color_black),0.5)]">
                            <canvas id="cpu_graph" class="w-full h-full"></canvas>
                        </div>
                        <div class="text-xs mt-1 text-right font-['Fira_Mono']" id="cpu_percent">0.0%</div>
                    </div>
                    <div class="edex-panel p-2 flex-grow" data-augmented-ui="tl-clip br-clip exe">
                        <h4 class="text-xs mb-1 border-b border-[rgba(var(--color_r),var(--color_g),var(--color_b),0.3)]">RAM Usage</h4>
                        <div class="h-16 w-full border border-[rgba(var(--color_r),var(--color_g),var(--color_b),0.3)] bg-[rgba(var(--color_black),0.5)]">
                            <canvas id="ram_graph" class="w-full h-full"></canvas>
                        </div>
                        <div class="text-xs mt-1 text-right font-['Fira_Mono']" id="ram_percent">0% / 8GB</div>
                    </div>
                </ModColumnLeft>
            </div>

            <!-- Center Column (Main Shell) -->
            <div class="w-2/4 h-full relative">
                <MainShell />
            </div>

            <!-- Right Column -->
            <div class="w-1/4 h-full">
                <ModColumnRight>
                    <div class="edex-panel p-2 text-center flex-grow flex flex-col justify-center items-center" data-augmented-ui="tr-clip bl-clip exe">
                        <div id="clock_time" class="text-3xl font-['Fira_Mono'] font-bold tracking-widest text-shadow">00:00:00</div>
                        <div id="clock_date" class="text-xs mt-2 font-['Fira_Mono']">1970-01-01</div>
                    </div>
                    <div class="edex-panel p-2 flex-grow text-xs" data-augmented-ui="tl-clip br-clip exe">
                        <h4 class="border-b border-[rgba(var(--color_r),var(--color_g),var(--color_b),0.3)] mb-2 pb-1">Network</h4>
                        <div class="flex justify-between font-['Fira_Mono'] mb-1"><span>IP:</span><span>127.0.0.1</span></div>
                        <div class="flex justify-between font-['Fira_Mono'] mb-2"><span>PING:</span><span id="ping_val">10ms</span></div>
                        <div class="mt-4 text-green-400 font-['Fira_Mono'] bg-[rgba(0,255,0,0.1)] p-1">▼ RX: <span id="net_rx">0</span> KB/s</div>
                        <div class="mt-1 text-red-400 font-['Fira_Mono'] bg-[rgba(255,0,0,0.1)] p-1">▲ TX: <span id="net_tx">0</span> KB/s</div>
                    </div>
                </ModColumnRight>
            </div>
        </div>

        <!-- Bottom row: Filesystem + Keyboard -->
        <div class="flex-grow flex flex-row gap-4 mt-4 h-[35%]">
            <div class="w-1/3 h-full">
                <FileSystem />
            </div>
            <div class="w-2/3 h-full flex items-end">
                <Keyboard />
            </div>
        </div>
    </div>

    <script src="../scripts/main.js"></script>
</Layout>

<style>
    .text-shadow {
        text-shadow: 0 0 10px rgba(var(--color_r), var(--color_g), var(--color_b), 0.8);
    }
</style>
