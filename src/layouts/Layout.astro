---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>eDEX-UI (Web Clone)</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
        <style is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
            @font-face { font-family: "Fira Mono"; src: url(var(--base)"assets/fonts/fira_mono.woff2") format("woff2"); }
            @font-face { font-family: "Fira Code"; src: url(var(--base)"assets/fonts/fira_code.woff2") format("woff2"); }
            @font-face { font-family: "United Sans Medium"; src: url(var(--base)"assets/fonts/united_sans_medium.woff2") format("woff2"); }
            @font-face { font-family: "United Sans Light"; src: url(var(--base)"assets/fonts/united_sans_light.woff2") format("woff2"); }
        </style>
        <script define:vars={{ base: import.meta.env.BASE_URL }}>
            // Apply theme on load
            const applyTheme = async (themeName) => {
                const res = await fetch(`${base}assets/themes/${themeName}.json`);
                if (res.ok) {
                    const theme = await res.json();
                    document.documentElement.style.setProperty('--color_r', theme.colors.r);
                    document.documentElement.style.setProperty('--color_g', theme.colors.g);
                    document.documentElement.style.setProperty('--color_b', theme.colors.b);
                    document.documentElement.style.setProperty('--color_black', theme.colors.black);
                    document.documentElement.style.setProperty('--color_light_black', theme.colors.light_black);
                    document.documentElement.style.setProperty('--color_grey', theme.colors.grey);

                    window.currentTheme = theme;
                    document.dispatchEvent(new CustomEvent('theme-changed', { detail: theme }));
                }
            };

            // Initialize theme
            const savedTheme = localStorage.getItem('edex-theme') || 'tron';
            applyTheme(savedTheme);

            window.changeTheme = (name) => {
                localStorage.setItem('edex-theme', name);
                applyTheme(name);
            };
        </script>
	</head>
	<body class="solidBackground" data-augmented-ui-reset>
        <div id="boot_screen"></div>
		<slot />
	</body>
</html>
