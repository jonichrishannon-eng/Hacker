---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>eDEX-UI (Web Clone)</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
        <style is:inline set:html={`
            @font-face { font-family: "Fira Mono"; src: url("${(import.meta.env.BASE_URL + '/assets/fonts/fira_mono.woff2').replace('//', '/')}") format("woff2"); }
            @font-face { font-family: "Fira Code"; src: url("${(import.meta.env.BASE_URL + '/assets/fonts/fira_code.woff2').replace('//', '/')}") format("woff2"); }
            @font-face { font-family: "United Sans Medium"; src: url("${(import.meta.env.BASE_URL + '/assets/fonts/united_sans_medium.woff2').replace('//', '/')}") format("woff2"); }
            @font-face { font-family: "United Sans Light"; src: url("${(import.meta.env.BASE_URL + '/assets/fonts/united_sans_light.woff2').replace('//', '/')}") format("woff2"); }
        `} />
        <script define:vars={{ base: import.meta.env.BASE_URL }}>
            const hexToRgb = (hex) => {
                let r = 0, g = 0, b = 0;
                if (hex.length === 4) {
                    r = parseInt(hex[1] + hex[1], 16);
                    g = parseInt(hex[2] + hex[2], 16);
                    b = parseInt(hex[3] + hex[3], 16);
                } else if (hex.length === 7) {
                    r = parseInt(hex.substring(1, 3), 16);
                    g = parseInt(hex.substring(3, 5), 16);
                    b = parseInt(hex.substring(5, 7), 16);
                }
                return `${r}, ${g}, ${b}`;
            };

            // Apply theme on load
            const applyTheme = async (themeName) => {
                const res = await fetch(`${base}/assets/themes/${themeName}.json`.replace('//', '/'));
                if (res.ok) {
                    const theme = await res.json();
                    document.documentElement.style.setProperty('--color_r', theme.colors.r);
                    document.documentElement.style.setProperty('--color_g', theme.colors.g);
                    document.documentElement.style.setProperty('--color_b', theme.colors.b);
                    document.documentElement.style.setProperty('--color_black', hexToRgb(theme.colors.black));
                    document.documentElement.style.setProperty('--color_light_black', hexToRgb(theme.colors.light_black));
                    document.documentElement.style.setProperty('--color_grey', hexToRgb(theme.colors.grey));

                    window.currentTheme = theme;
                    document.dispatchEvent(new CustomEvent('theme-changed', { detail: theme }));
                }
            };

            // Initialize theme
            const savedTheme = localStorage.getItem('edex-theme') || 'tron';
            applyTheme(savedTheme);

            window.changeTheme = (name) => {
                localStorage.setItem('edex-theme', name);
                applyTheme(name);
            };
        </script>
	</head>
	<body class="solidBackground" data-augmented-ui-reset>
        <div id="boot_screen"></div>
		<slot />
	</body>
</html>
